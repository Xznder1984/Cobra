// Calculator in Cobra
// A basic arithmetic calculator

fn main():
    let x = 42
    let y = 7
    
    print("x + y = ")
    print_int(x + y)
    println()
    
    print("x - y = ")
    print_int(x - y)
    println()
    
    print("x * y = ")
    print_int(x * y)
    println()
    
    print("x / y = ")
    print_int(x / y)
    println()