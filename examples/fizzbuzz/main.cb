// FizzBuzz in Cobra

fn main() {
    println("FizzBuzz")
    println("========")
    
    for i in 1..=100 {
        if i % 15 == 0 {
            println("FizzBuzz")
        } elif i % 3 == 0 {
            println("Fizz")
        } elif i % 5 == 0 {
            println("Buzz")
        } else {
            println(i)
        }
    }
}
