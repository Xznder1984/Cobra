// Loop examples in Cobra

fn main():
    print("For loop 1..5:")
    for i in 1..6:
        print(i)

    print("Done1")

    print("For loop 1..=5:")
    for i in 1..=5:
        print(i)

    print("Done2")

    print("While loop:")
    count = 0
    while count < 5:
        print(count)
        count = count + 1

    print("Done3")