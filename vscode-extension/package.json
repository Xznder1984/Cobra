{
  "name": "cobra-lang",
  "displayName": "Cobra Language",
  "description": "Cobra programming language support",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xznder1984/Cobra.git"
  },
  "publisher": "cobra-lang",
  "icon": "../branding/cobra-icon-512.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:cobra"
  ],
  "main": "./out/extension",
  "contributes": {
    "languages": [
      {
        "id": "cobra",
        "aliases": [
          "Cobra"
        ],
        "extensions": [
          ".cb"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cobra",
        "scopeName": "source.cobra",
        "path": "./syntaxes/cobra.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "cobra",
        "path": "./snippets/cobra.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Xznder1984/Cobra/issues"
  },
  "homepage": "https://github.com/Xznder1984/Cobra#readme",
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "typescript": "^6.0.3"
  }
}
